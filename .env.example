# Tailscale API Configuration
TAILSCALE_CLIENT_ID=your_client_id_here
TAILSCALE_CLIENT_SECRET=your_client_secret_here
TAILSCALE_TAILNET=your_tailnet_here
INITIAL_AUTH_KEY=your_initial_auth_key_here

# System Configuration
COMPANY_NAME=YourCompany
ADMIN_EMAIL=admin@example.com
IT_CONTACT=it@example.com
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Database
REDIS_URL=redis://redis:6379

# Email Configuration (Optional - for notifications)
EMAIL_ENABLED=false
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=admin@example.com
SMTP_PASS=your_email_password
SMTP_ENCRYPTION=tls
FROM_EMAIL=admin@example.com

# System Settings
LOG_LEVEL=info
API_PORT=3000
WEB_PORT=8080